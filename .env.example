# ─── Google Maps / Places API ───────────────────────────────────────────────
# Získat na: https://console.cloud.google.com/ → APIs & Services → Credentials
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Google Gemini AI ────────────────────────────────────────────────────────
# Získat na: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Odesílací email (SMTP) ──────────────────────────────────────────────────
EMAIL_USER=your_email@gmail.com
# Pro Gmail použij App Password (ne běžné heslo):
# https://myaccount.google.com/apppasswords
EMAIL_PASSWORD=your_app_password_here

# SMTP nastavení (výchozí hodnoty fungují pro Gmail)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# ─── Dev mód ─────────────────────────────────────────────────────────────────
# Nastav na True pro testování bez API klíčů (vrací mock data)
DEV_MODE=False
